{
  "name": "video_understanding",
  "description": "读取原视频并输出结构化视频拆解结果，保留现有RunningHub video-to-text处理方式。",
  "input_schema": {
    "type": "object",
    "required": ["project_id", "task_id", "video_path", "prompt"],
    "properties": {
      "project_id": { "type": "string" },
      "task_id": { "type": "string" },
      "video_path": { "type": "string" },
      "prompt": { "type": "string", "minLength": 1 },
      "original_asset_id": { "type": ["string", "null"] }
    }
  },
  "output_schema": {
    "type": "string",
    "description": "现有格式化视频理解文本；后续由cleanBreakdownForResponse与parseBreakdownResult处理。"
  },
  "provider": "RunningHub",
  "model": "rhart-text-g-25-flash/video-to-text",
  "timeout": { "milliseconds": 1200000, "source": "RH_MAX_POLL_SECONDS" },
  "retry_policy": { "max_retries": 5, "strategy": "exponential_backoff", "retryable": ["network_error", "provider_5xx", "rate_limit"], "non_retryable": ["content_rejected", "invalid_input", "cancelled"] },
  "error_codes": ["TASK_TIMEOUT", "MODEL_UNAVAILABLE", "MODEL_REQUEST_FAILED", "MODEL_RATE_LIMITED", "MODEL_CONTENT_REJECTED", "MODEL_RESULT_INVALID"],
  "cost_rule": { "type": "provider_usage", "source": "RunningHub response usage.consumeMoney", "user_points": false },
  "implementation_files": ["backend/server.js#runVideoToTextDirect", "backend/server.js#pollRunningHubTask", "backend/services/taskResultService.js"],
  "standalone_test": "node --test --test-name-pattern='video understanding skill' test/coreSkills.test.js"
}

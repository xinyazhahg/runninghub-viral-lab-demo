{
  "name": "video_generation",
  "description": "使用现有模型配置、Prompt和参考图生成视频，输出保持现有RunningHub脚本格式。",
  "input_schema": {
    "type": "object",
    "required": ["project_id", "task_id", "prompt", "model_id", "model_endpoint", "duration", "aspect_ratio", "resolution"],
    "properties": {
      "project_id": { "type": "string" },
      "task_id": { "type": "string" },
      "image_path": { "type": ["string", "null"], "description": "首次提交必填；已有external_task_id的恢复轮询可为空。" },
      "prompt": { "type": "string", "minLength": 1 },
      "model_id": { "type": "string" },
      "model_endpoint": { "type": "string" },
      "duration": { "type": "number" },
      "aspect_ratio": { "type": "string" },
      "resolution": { "type": "string" },
      "source_video_storage_path": { "type": ["string", "null"] },
      "resume_external_task_id": { "type": ["string", "null"] }
    }
  },
  "output_schema": {
    "type": "string",
    "description": "现有RunningHub脚本stdout，包含TASK_ID、OUTPUT_FILE、COST和DURATION标记。"
  },
  "provider": "RunningHub",
  "model": "由model_configs读取，当前新任务仅允许 Seedance 2.0；历史任务保留原模型记录",
  "timeout": { "milliseconds": 1200000, "source": "runninghub.js MAX_POLL_SECONDS" },
  "retry_policy": { "max_retries": 5, "strategy": "exponential_backoff", "retryable": ["poll_network_error", "provider_5xx", "rate_limit"], "non_retryable": ["content_rejected", "invalid_parameters", "balance_insufficient", "cancelled"] },
  "error_codes": ["TASK_TIMEOUT", "TASK_CANCELLED", "MODEL_UNAVAILABLE", "MODEL_REQUEST_FAILED", "MODEL_RATE_LIMITED", "MODEL_CONTENT_REJECTED", "MODEL_RESULT_INVALID", "BALANCE_INSUFFICIENT"],
  "cost_rule": { "type": "model_config", "source": "model_configs.cost_rule + RunningHub actual cost", "settlement": "existing billingService Task transaction" },
  "implementation_files": ["backend/server.js#generate-video", "backend/scripts/runninghub.js", "backend/lib/modelConfig.js", "backend/lib/generationConfig.js"],
  "standalone_test": "node --test --test-name-pattern='video generation skill' test/coreSkills.test.js"
}

# Required for backend RunningHub requests.
# Do not commit real keys.
RUNNINGHUB_API_KEY=

# Deployment platform port. Render/Railway usually inject this automatically.
PORT=3000

# Frontend origins allowed by CORS.
FRONTEND_ORIGIN=http://localhost:5173
CORS_ORIGINS=

# Optional: overrides the local RunningHub skill directory.
RUNNINGHUB_SKILL_DIR=

# Optional: required only for /api/extract-element-preview.
RUNNINGHUB_SAM_WORKFLOW_ID=
SAM_IMAGE_NODE_ID=
SAM_TEXT_NODE_ID=
SAM_IMAGE_FIELD_NAME=image
SAM_TEXT_FIELD_NAME=text

# Frontend does not use RunningHub API keys.
# Keep RUNNINGHUB_API_KEY configured only in the backend environment.

# Empty in local development so Vite proxy can request /api and /generated.
# Set this to the deployed backend origin in production, without a trailing slash.
VITE_API_BASE_URL=

# Supabase is accessed by the backend in this round. Never expose
# SUPABASE_SERVICE_ROLE_KEY through a VITE_ variable.

# Example:
# VITE_API_BASE_URL=https://your-backend.example.com

# Supabase Auth public configuration. The anon key is designed for frontend use.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Never expose SUPABASE_SERVICE_ROLE_KEY through a VITE_ variable.
